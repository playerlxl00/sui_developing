# start by cloning the "Hello, World!" example:

git clone https://github.com/MystenLabs/sui-stack-hello-world.git
cd sui-stack-hello-world/move/hello-world

# In sui-stack-hello-world/move/hello-world/Move.toml, find [dependencies] section, comment it out (bcz new versions of sui has already automatically added these dependencies, if we manually add again, they will conflict so that our subsequent operations will fail)

# Initialize the Git configuration
git config --global user.name "Your name"  // just name you want to present in code submission report
git config --global user.email "Youremail@example.com"

# Build the Move package
sui move build
# Only when it shows sth like below it is successful
# INCLUDING DEPENDENCY Bridge
# INCLUDING DEPENDENCY SuiSystem
# INCLUDING DEPENDENCY Sui
# INCLUDING DEPENDENCY MoveStdlib
# BUILDING hello_world

# Build a testnet
sui client new-env --alias testnet --rpc https://fullnode.testnet.sui.io:443

# Check all of your envs
sui client envs

# Publish the Move package (After you publish it, other packages and users can use the package's modules and functions by making calls to the package ID)
sui client active-env
# If the return is not 'testnet'
sui client switch --env testnet

# Check your balance of SUI tokens
sui client balance
# If you do not have a balance, follow the SUI faucet instructions

# Now, publish the package to Testnet with the command:
sui client publish

