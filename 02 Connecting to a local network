# This is to build a self-owned, free sui test environment

# Starting the local network (If wanting to stop, Ctrl+C)
sui start --with-faucet

# Create a new terminal

# 1. Check current environment
sui client envs

# 2. Create local environment (pointing to local network)
sui client new-env --alias local --rpc http://127.0.0.1:9000

# 3. Switch to local environment
sui client switch --env local

# 4. Create a new address (Needed when using firstly)
sui client new-address ed25519

# This command specifies the key pair scheme to be of type ed25519.

# The options are:

# ed25519: Small key size and compact signatures.

# secp256k1: Provides security through generating and verifying keys using ECDSA.

# secp256r1: Uses randomly generated curves to generate keys.

# 5. Check all addresses
sui client addresses

# To update the alias to something else, use the command

sui keytool update-alias <OLD-ALIAS> <NEW-ALIAS>

# 6. Check details of all addresses
sui keytool list

# 7. Check active address
sui client active-address

# Change active address
sui client switch --address <ADDRESS>

# 8. Get testing coins from the faucet (Note that these coins are only sent to active addresses)
sui client faucet

# You may also require coins from https://faucet.sui.io/

# 9. Wait for a few seconds and checking coins gotten
sui client gas

# 10. Check balance of active address
sui client balance

# 11. Check objects of addresses (If an address is not provided, this command returns all objects owned by the active address)
sui client objects <ADDRESS>

# 12. To recover an address using the recovery phrase, use the command ('Replace '<RECOVERY_PHRASE>' with your 12-word recovery phrase. The entire recovery phrase must be enclosed in single quotation marks '. You must enter the words in the correct order.Replace <KEY_SCHEME> with the type of encryption used to originally create the address, such as ed25519.If successful, the CLI restores your address and prints it in the CLI output')
sui keytool import '<RECOVERY_PHRASE>' <KEY_SCHEME>
