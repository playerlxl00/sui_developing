# Create an object (struct is like a table or database, an object is just a struct set at the very beginning, then you do some operations to the struct to make the object 'some kind of object')
struct Object has key {
    id: UID,
    value: u64,
}

# Something before {} is 'Ability', which is a type being returned to
# There are 4 common ability in sui:
# key: Can be regard as object (has unique id) (for all objects)
# store: Can be stored in other objects and freely transferred (for those objects needed to be transferred freely)
# copy:	Can be copied	(for simple numerical types (such as configuration))
# drop:	Can be discarded (no need for explicit destruction)	(temporary data)
# Common combinations:
// 1. Most basic object (cannot transfer freely)
struct Trophy has key {
    id: UID,
    points: u64,
}

// 2. Object that can be transferred freely (e.g. NFT)
struct NFT has key, store {
    id: UID,
    name: vector<u8>,
}

// 3. Objects that can be copied (e.g. configuration)
struct Config has copy, drop {
    version: u64,
    fee_rate: u64,
}

// 4. Values that can be copied and stored
struct Stats has copy, store, drop {
    strength: u64,
    agility: u64,
}

# Note that not all things in sui can be stored, which means you can only lend them by & (we will further discuss), for example some system-level types:
# TxContext: Transaction environment, for example sender, recipient, etc., discard right after transaction ending
# UID: Object id card
# Clock  Global clock, can only be read
# Random  Random number generator, independent in each transaction

# &T: Immutable reference, can only be read, not written
# &mut T: Mutable reference, can be read and written
# T: Value (Ownership Transfer), full Ownership, Can Be Destroyed
# We don't have 'mut T', because the overall idea is, if the ownership has already been transferred, you can do whatever changes or not, just decide by yourself. We only have to divide into categories to discuss only when it is being borrowed, to discuss whether or not you can make changes

// This is the same as "f(x) = "，the thing before () is the 'f', and those inside () are parameters
public fun create(value: u64, recipient: address, ctx: &mut TxContext) {
    // Here is the detailed content for '=', which is the function body
    transfer::public_transfer(
        Object { id: object::new(ctx), value },
        recipient,
    )
}

# TxContext standard using format
use sui::tx_context::{Self, TxContext};
use sui::object::{Self, UID};
use sui::transfer;

// TxContext as a parameter, it is always &mut
public fun create_object(value: u64, ctx: &mut TxContext) {
    // 1. Read the information of tx_context
    let sender = tx_context::sender(ctx);           // Who is making the call
    let timestamp = tx_context::timestamp_ms(ctx);  // What is the timepoint
    let epoch = tx_context::epoch(ctx);             // Current epoch
    
    // 2. Create new object ID by ctx
    let new_id = object::new(ctx);
    
    // 3. Create object
    let obj = MyObject {
        id: new_id,
        value: value,
        created_by: sender,
        created_at: timestamp,
    };
    
    // 4. Transfer to the sender
    transfer::transfer(obj, sender);
}

// Passing ctx between multiple functions
public fun chain_calls(ctx: &mut TxContext) {
    create_object(100, ctx);  // Pass the same ctx down
    create_object(200, ctx);  // The "ids_created" value will increase continuously
}

# UID standard using format
use sui::object::{Self, UID, ID};
use sui::tx_context::TxContext;

// UID is always the first field of the object
struct MyObject has key {
    id: UID,           // Must be the first field of the object
    value: u64,
}

struct Container has key, store {
    id: UID,
    target_id: ID,     // An ID can be used to point to another object
}

// Create UID：only by object::new(ctx)
public fun create_uid_example(ctx: &mut TxContext): UID {
    object::new(ctx)   // Return a new UID
}

// UID cannot be copied, can only be transferred
public fun move_uid(uid: UID, new_owner: address) {
    transfer::transfer(uid, new_owner);  // UID itself can be transferred as object
}

// Gather ID of object (This is an ID type, not UID)
public fun get_object_id(obj: &MyObject): ID {
    object::id(obj)    // Return the address of an object of the ID type
}

// Store the ID of other objects
public fun store_id(container: &mut Container, target: &MyObject) {
    container.target_id = object::id(target);  // What is stored is ID rather than UID
}

# Quick Overview of Clock and Random
use sui::clock::Clock;
use sui::random::Random;

// Clock: Global clock, can only read the time
public fun get_time(ctx: &TxContext, clock: &Clock) {
    let now = clock::timestamp_ms(clock);  // Current timestamp
    // Clock only use &, not &mut, because you can't change the time
}

// Random：The random number generator, requiring &mut because its internal state will change
public fun roll_dice(rng: &mut Random, ctx: &TxContext) {
    let roll = random::u64_range(rng, 1, 7);  // Random numbers from 1 to 6
}

